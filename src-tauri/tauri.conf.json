{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Vidnovagram",
  "version": "0.2.0",
  "identifier": "app.vidnova.vidnovagram",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Vidnovagram",
        "width": 1100,
        "height": 750,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' https://cc.vidnova.app wss://cc.vidnova.app; img-src 'self' https://cc.vidnova.app data: blob:; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEQ2MkFENjRFMkYwNEM1NjYKUldSbXhRUXZUdFlxMXAwd0h0bUpVQW9ybEw3MEtkb1FJZG5CSDhBdzlVU1lpKzZpTTFwSXZ6UHgK",
      "endpoints": [
        "https://github.com/Alex1981-tech/Vidnovagram/releases/latest/download/latest.json"
      ]
    }
  }
}
