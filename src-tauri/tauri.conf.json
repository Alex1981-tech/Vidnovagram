{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Vidnovagram",
  "version": "0.10.3",
  "identifier": "app.vidnova.vidnovagram",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Vidnovagram",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "maximizable": true,
        "maximized": true,
        "fullscreen": false,
        "center": true,
        "decorations": true,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' ipc: http://ipc.localhost https://cc.vidnova.app wss://cc.vidnova.app; img-src 'self' https: data: blob:; media-src 'self' data: blob: mediastream:; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDI2RTQ4RDJBQ0I0MzQ0RTMKUldUalJFUExLbzNrSnZvT1MyNVZ3VFQ3d3NidWVBeG9XK0ozaGUwdit5OWFyQVVzQVNCUE1qeUIK",
      "endpoints": [
        "https://github.com/Alex1981-tech/Vidnovagram/releases/latest/download/latest.json"
      ]
    }
  }
}
